# Saiyan Tracker Production Environment
# Copy to /etc/saiyan-tracker.env and fill in values
# Permissions: chmod 640 /etc/saiyan-tracker.env && chown root:saiyan /etc/saiyan-tracker.env

# Absolute path to SQLite database (four slashes: sqlite:/// prefix + /absolute/path)
DATABASE_URL=sqlite:////home/user/saiyan-tracker/backend/saiyan_tracker.db

# Comma-separated list of allowed CORS origins (your Vercel frontend URL)
CORS_ORIGINS=https://your-app.vercel.app
